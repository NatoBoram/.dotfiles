{
	"lspServers": {
		"dart": {
			"args": ["language-server"],
			"command": "dart",
			"fileExtensions": { ".dart": "dart" }
		},
		"go": { "command": "gopls", "fileExtensions": { ".go": "go" } },
		"rust": { "command": "rust-analyzer", "fileExtensions": { ".rs": "rust" } },
		"svelte": {
			"args": ["svelte-language-server@latest", "--stdio"],
			"command": "bunx",
			"fileExtensions": { ".svelte": "svelte" }
		},
		"turbo": {
			"args": ["turbo@latest", "daemon"],
			"command": "bunx",
			"fileExtensions": { ".json": "json" }
		},
		"typescript": {
			"args": ["--lsp", "--stdio"],
			"command": "tsgo",
			"fileExtensions": {
				".cjs": "javascript",
				".cts": "typescript",
				".js": "javascript",
				".jsx": "javascript",
				".mjs": "javascript",
				".mts": "typescript",
				".ts": "typescript",
				".tsx": "typescript"
			}
		}
	}
}
